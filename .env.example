# --- Runtime config (read via python-dotenv) ---
API_KEY=change-me
# Optional: additional accepted keys, comma-separated (merged with API_KEY).
# API_KEYS=key1,key2
HOST=0.0.0.0
PORT=8000
MAX_CONCURRENT=5
TIMEOUT=120
MAX_FILE_SIZE=10485760

# Contamination isolation: "clean" (default; system-prompt override + no settings,
# keeps the machine's Claude subscription/OAuth) or "bare" (--bare; requires ANTHROPIC_API_KEY).
ISOLATION_MODE=clean
# ANTHROPIC_API_KEY=   # required only when ISOLATION_MODE=bare

# Editable model map (hot-reloaded by mtime). DEFAULT_MODEL overrides its "default" when set.
MODELS_FILE=models.json
# DEFAULT_MODEL=sonnet

# --- Deployment config (used to template claude-gateway.service) ---
# systemd cannot expand ${VAR} in User=/Group=/WorkingDirectory=/EnvironmentFile=,
# so these must match the values hard-coded in claude-gateway.service.
# HOST and PORT above ARE read by the unit's ExecStart at runtime.
SERVICE_USER=gateway
SERVICE_GROUP=gateway
INSTALL_DIR=/home/gateway/claude-gateway
