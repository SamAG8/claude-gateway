# --- Runtime config (read by main.py via python-dotenv) ---
API_KEY=change-me
HOST=0.0.0.0
PORT=8000
MAX_CONCURRENT=5
TIMEOUT=120
UPLOAD_DIR=/tmp/gateway-uploads
MAX_FILE_SIZE=10485760

# --- Deployment config (used to template claude-gateway.service) ---
# systemd cannot expand ${VAR} in User=/Group=/WorkingDirectory=/EnvironmentFile=,
# so these must match the values hard-coded in claude-gateway.service.
# HOST and PORT above ARE read by the unit's ExecStart at runtime.
SERVICE_USER=gateway
SERVICE_GROUP=gateway
INSTALL_DIR=/home/gateway/claude-gateway
