[Unit]
Description=Claude Gateway
After=network.target

[Service]
Type=simple
# These must match SERVICE_USER / SERVICE_GROUP / INSTALL_DIR in .env
# (systemd does not expand ${VAR} in these directives).
User=gateway
Group=gateway
WorkingDirectory=/home/gateway/claude-gateway
EnvironmentFile=/home/gateway/claude-gateway/.env
# HOST and PORT are read from the EnvironmentFile above at runtime.
ExecStart=/home/gateway/claude-gateway/.venv/bin/uvicorn main:app --host ${HOST} --port ${PORT}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
